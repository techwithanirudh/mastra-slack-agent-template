# Copy to .env and fill in your secrets (.env is gitignored).

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV="development"

# ----------------------------------------------------------------------------
# Slack
# ----------------------------------------------------------------------------
# App-level token for Socket Mode (connections:write). https://api.slack.com/apis/connections/socket
SLACK_APP_TOKEN="xapp-your-app-token"
# Bot User OAuth Token (OAuth & Permissions)
SLACK_BOT_TOKEN="xoxb-your-bot-token"

# ----------------------------------------------------------------------------
# Models
# ----------------------------------------------------------------------------
# OpenRouter
OPENROUTER_API_KEY="sk-or-your-openrouter-api-key"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENCODE_API_KEY=""

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mastra_slack_agent"

# ----------------------------------------------------------------------------
# Code Sandbox (E2B). https://e2b.dev/
# ----------------------------------------------------------------------------
E2B_API_KEY="your-e2b-api-key"

# Optional brokered sandbox credentials. They stay on the host and are injected
# into matching outbound sandbox requests with E2B network rules.
AGENTMAIL_API_KEY="your-agentmail-api-key"
GITHUB_TOKEN="github_pat_your-fine-grained-token"

# ----------------------------------------------------------------------------
# Web search (Exa). https://exa.ai/
# ----------------------------------------------------------------------------
EXA_API_KEY="your-exa-api-key"
